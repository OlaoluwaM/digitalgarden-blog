<script>
    // Create callout icons
    window.addEventListener("load", () => {
        document.querySelectorAll(".callout").forEach((elem) => {
            const icon = getComputedStyle(elem).getPropertyValue('--callout-icon');
            const iconName = icon && icon.trim().replace(/^lucide-/, "");

            if (iconName) {
                const calloutTitle = elem.querySelector(".callout-title");

                if (calloutTitle) {
                    const calloutIconContainer = document.createElement("div");
                    const calloutIcon = document.createElement("i");

                    calloutIconContainer.appendChild(calloutIcon);
                    calloutIcon.setAttribute("data-lucide", iconName);
                    calloutIconContainer.setAttribute("class", "callout-icon");
                    calloutTitle.insertBefore(calloutIconContainer, calloutTitle.firstChild);
                }
            }
        });

        // Auto-make top-level callouts collapsible (nested callouts use explicit +/- syntax)
        document.querySelectorAll(".callout").forEach((elem) => {
            const hasCalloutAncestor = elem.parentElement && elem.parentElement.closest(".callout");
            // Only auto-add collapse to top-level callouts — nested ones require explicit opt-in via +/- in the Obsidian source.
            // Skip any already marked is-collapsible, since the build-time transform adds that class when +/- is present.
            if (!hasCalloutAncestor && !elem.classList.contains("is-collapsible")) {
                elem.classList.add("is-collapsible");
                const calloutTitle = elem.querySelector(".callout-title");
                if (calloutTitle) {
                    const fold = document.createElement("div");
                    fold.className = "callout-fold";
                    const icon = document.createElement("i");
                    icon.setAttribute("data-lucide", "chevron-down");
                    fold.appendChild(icon);
                    calloutTitle.appendChild(fold);
                }
            }
        });

        lucide.createIcons();

        // Collapse callouts
        Array.from(document.querySelectorAll(".callout.is-collapsible")).forEach((elem) => {
            const title = elem.querySelector('.callout-title');
            if (!title) return;
            title.setAttribute("tabindex", "0");
            title.setAttribute("role", "button");
            title.setAttribute("aria-expanded", elem.classList.contains("is-collapsed") ? "false" : "true");

            function toggle() {
                const isCollapsed = elem.classList.toggle("is-collapsed");
                title.setAttribute("aria-expanded", isCollapsed ? "false" : "true");
            }

            title.addEventListener("click", toggle);
            title.addEventListener("keydown", (event) => {
                if (event.key === "Enter" || event.key === " ") {
                    event.preventDefault();
                    toggle();
                }
            });
        });
    });
</script>
