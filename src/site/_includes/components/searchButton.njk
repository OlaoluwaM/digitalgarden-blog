<div class="search-button align-icon"
     role="button"
     tabindex="0"
     aria-label="{{ meta.uiStrings.searchButtonText }}"
     onclick="toggleSearch()"
     onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();toggleSearch()}">
    <span class="search-icon">
        <i data-lucide="search"></i>
    </span>
    <span class="search-text">{{ meta.uiStrings.searchButtonText }}</span>
    <span class="search-keys"><code>Ctrl</code>&nbsp;+&nbsp;<code>K</code></span>
</div>