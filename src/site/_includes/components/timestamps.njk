<script src="https://fastly.jsdelivr.net/npm/luxon@3.2.1/build/global/luxon.min.js"></script>
<script defer>
  (() => {
    const TIMESTAMP_FORMAT = "{{meta.timestampSettings.timestampFormat}}";

    document.querySelectorAll('.human-date').forEach(function(el) {
      const date = el.getAttribute('data-date') || el.innerText;
      let parsedDate = luxon.DateTime.fromISO(date);

      if (!parsedDate.isValid) {
        parsedDate = luxon.DateTime.fromSQL(date);
      }

      if (!parsedDate.isValid) {
        parsedDate = luxon.DateTime.fromHTTP(date);
      }

      if (parsedDate.isValid) {
        el.textContent = parsedDate.toFormat(TIMESTAMP_FORMAT);
      }
    });
  })();
</script>