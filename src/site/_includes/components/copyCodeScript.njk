<script>
    async function copyTextToClipboard(text) {
        if (typeof navigator !== "undefined" &&
            navigator.clipboard &&
            typeof navigator.clipboard.writeText === "function") {
            try {
                await navigator.clipboard.writeText(text);
                return true;
            } catch (e) {
                // Intentionally empty: swallow the error so execution falls
                // through to the execCommand textarea fallback below.
            }
        }

        try {
            const textarea = document.createElement("textarea");
            textarea.value = text;
            textarea.style.position = "fixed";
            textarea.style.top = "-1000px";
            textarea.style.left = "-1000px";
            document.body.appendChild(textarea);
            textarea.focus();
            textarea.select();
            const successful = document.execCommand("copy");
            document.body.removeChild(textarea);
            return successful;
        } catch (e) {
            return false;
        }
    }

    window.addEventListener("load", () => {
        document.querySelectorAll("pre.shiki").forEach((pre) => {
            const code = pre.querySelector("code");
            const btn = document.createElement("button");
            btn.className = "copy-code-btn";
            btn.type = "button";
            btn.textContent = "Copy";
            btn.addEventListener("click", async () => {
                const originalText = btn.textContent;
                const success = await copyTextToClipboard(code.textContent);
                if (success) {
                    btn.textContent = "Copied!";
                    setTimeout(() => { btn.textContent = "Copy"; }, 2000);
                } else {
                    btn.textContent = "Failed";
                    setTimeout(() => { btn.textContent = originalText; }, 2000);
                }
            });
            pre.appendChild(btn);
        });
    });
</script>
