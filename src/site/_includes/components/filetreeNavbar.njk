<nav class="navbar">
    <div class="navbar-inner">
        <button type="button" class="hamburger-btn" aria-label="Toggle navigation" :aria-expanded="showFilesMobile.toString()" @click="showFilesMobile=!showFilesMobile"><i data-lucide="menu"></i></button>
        {% for imp in dynamics.filetree.beforeTitle %}
            {% include imp %}
        {% endfor %}
        {% if meta.siteLogoPath %}
        <a href="/" style="text-decoration: none; flex: 1; display: flex; justify-content: center;">
                <img class="site-logo" src="{{meta.siteLogoPath}}" alt="{{meta.siteName}}">
        </a>
        {% else %}
        <a href="/" style="text-decoration: none;">
                <h1 class="site-name-header">{{meta.siteName}}</h1>
        </a>
        {% endif %}
        {% for imp in dynamics.filetree.afterTitle %}
            {% include imp %}
        {% endfor %}
    </div>

    {% if settings.dgEnableSearch === true%}
        {% include "components/searchButton.njk" %}
    {%endif%}
</nav>
